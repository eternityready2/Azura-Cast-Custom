# -----------------------------------------------------------------------------
# Line endings: always LF in repo (no CRLF warnings on push/pull).
# Git will normalize on commit and convert on checkout per platform if needed.
# -----------------------------------------------------------------------------
* text=auto eol=lf

# Explicit LF for all text (redundant but explicit for tooling)
*.sh text eol=lf
*.bash text eol=lf
Dockerfile text eol=lf
*.cnf text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.php text eol=lf
*.blade.php text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.less text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.env text eol=lf
*.sample text eol=lf
vagrant_* text eol=lf
*.neon text eol=lf
*.twig text eol=lf
*.feature text eol=lf

# Binary: never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

# Files that should be excluded from the Release zip/gz's
/.github export-ignore
/.editorconfig export-ignore
/tests export-ignore
/util/docker export-ignore
/util/openapi.php export-ignore
/util/phpstan.php export-ignore
/util/unused.php export-ignore
/*.yml export-ignore
/*.yaml export-ignore
/*.neon export-ignore
/*.md export-ignore
/.travis.yml export-ignore
/docker.sh export-ignore
