#: frontend/components/Admin/Stations/Form/AdminForm.vue:31
msgid "The maximum bitrate in which the station allowed to broadcast at, in Kbps. 0 for unlimited."
msgstr "Maksymalna przepustowość, z jaką stacja może nadawać, w Kbps. 0 oznacza brak ograniczeń."

#: frontend/components/Admin/Stations/Form/AdminForm.vue:39
msgid "Maximum Mounts"
msgstr "Maksymalna liczba punktów montowania"

#: frontend/components/Admin/Stations/Form/AdminForm.vue:40
msgid "The maximum number of mount points allowed. 0 for unlimited."
msgstr "Maksymalna liczba punktów montowania. 0 dla nieograniczonych."

#: frontend/components/Admin/Stations/Form/AdminForm.vue:48
msgid "Maximum HLS Streams"
msgstr "Maksymalne strumienie HLS"

#: frontend/components/Admin/Stations/Form/AdminForm.vue:49
msgid "The maximum number of HLS streams allowed. 0 for unlimited."
msgstr "Maksymalna liczba dozwolonych strumieni HLS. 0 oznacza brak ograniczeń."

#: frontend/components/Admin/Stations/Form/AdminForm.vue:61
msgid "Media Storage Location"
msgstr "Lokalizacja przechowywania mediów"

#: frontend/components/Admin/Stations/Form/AdminForm.vue:69
msgid "Live Recordings Storage Location"
msgstr "Lokalizacja zapisu nagrań transmisji na żywo"

#: frontend/components/Admin/Stations/Form/AdminForm.vue:77
msgid "Podcasts Storage Location"
msgstr "Lokalizacja Przechowywania Podcastów"

#: frontend/components/Admin/Stations/Form/AdminForm.vue:125
msgid "Create a new storage location based on the base directory."
msgstr "Utwórz nową lokalizację przechowywania na podstawie katalogu bazowego."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:14
#: frontend/components/Stations/Profile/BackendPanel.vue:12
msgid "AutoDJ Service"
msgstr "Usługa autopilota"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:15
msgid "This software shuffles from playlists of music constantly and plays when no other radio source is available."
msgstr "To oprogramowanie nieprzerwanie losuje utwory z playlisty i odtwarza je, gdy nie jest dostępne żadne inne źródło sygnału radia."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:29
msgid "Crossfade Method"
msgstr "Metoda przejścia"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:30
msgid "Choose a method to use when transitioning from one song to another. Smart Mode considers the volume of the two tracks when fading for a smoother effect, but requires more CPU resources."
msgstr "Wybierz metodę, jaką chcesz wykorzystywać do tworzenia przejść pomiędzy utworami. Tryb Inteligentny (Smart Mode), dla płynniejszego efektu, sprawdza głośność obydwu utworów, wymaga jednak większego użycia mocy obliczeniowej procesora."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:39
msgid "Crossfade Duration (Seconds)"
msgstr "Czas trwania przejścia (w sekundach)"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:40
msgid "Number of seconds to overlap songs."
msgstr "Długość nakładania się utworów w sekundach."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:47
msgid "Audio Processing"
msgstr "Przetwarzanie dźwięku"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:51
msgid "Apply audio processors (like compressors, limiters, or equalizers) to your stream to create a more uniform sound or enhance the listening experience. Processing requires extra CPU resources, so it may slow down your server."
msgstr "Zastosuj procesory audio (takie jak kompresory, ograniczniki lub korektory) do strumienia, aby stworzyć bardziej jednolity dźwięk lub poprawić wrażenia z odsłuchu. Przetwarzanie wymaga dodatkowych zasobów CPU, więc może spowolnić serwer."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:56
msgid "Learn More about Post-processing CPU Impact"
msgstr "Dowiedz się więcej o wpływie postprodukcji na CPU"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:64
msgid "Enable AutoCue (Beta)"
msgstr "Włącz AutoCue (Beta)"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:69
msgid "AutoCue analyzes your music and automatically calculates cue points, fade points, and volume levels for a consistent listening experience."
msgstr "AutoCue analizuje muzykę i automatycznie oblicza punkty orientacyjne (cue points), punkty zanikania (fade points) i poziomy głośności dla spójnego doświadczenia słuchania."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:75
msgid "Learn more about AutoCue"
msgstr "Dowiedz się więcej o AutoCue"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:84
msgid "Enable ReplayGain"
msgstr "Włącz ReplayGain"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:89
msgid "Calculate and use normalized volume level metadata for each track."
msgstr "Oblicz i użyj znormalizowanych metadanych poziomu głośności dla każdego utworu."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:103
msgid "Audio Post-processing Method"
msgstr "Metoda postprodukcji dźwięku"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:104
msgid "Select an option here to apply post-processing using an easy preset or tool. You can also manually apply post-processing by editing your Liquidsoap configuration manually."
msgstr "Zaznacz tutaj opcję, aby zastosować postprodukcję przy użyciu prostego presetu lub narzędzia. Możesz również ręcznie zastosować postprodukcję poprzez ręczną edycję konfiguracji Liquidsoap."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:113
msgid "Apply Post-processing to Live Streams"
msgstr "Zastosuj postprodukcję dźwięku w strumieniach na żywo"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:114
msgid "Check this box to apply post-processing to all audio, including live streams. Uncheck this box to only apply post-processing to the AutoDJ."
msgstr "Zaznacz to pole, aby zastosować postprodukcję do wszystkich audio, włącznie z transmisjami na żywo. Odznacz to pole, aby zastosować postprodukcję tylko do autopilota."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:122
msgid "About Master_me"
msgstr "Informacje o Master_me"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:127
msgid "Master_me is an open-source automatic mastering plugin for streaming, podcasts and Internet radio."
msgstr "Master_me jest otwartoźródłową automatyczną wtyczką dla strumieniowania, podcastów i radia internetowego."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:135
msgid "Master_me Project Homepage"
msgstr "Strona domowa projektu Master_me"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:148
msgid "Master_me Preset"
msgstr "Preset Master_me"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:157
msgid "Master_me Loudness Target (LUFS)"
msgstr "Głośność docelowa Master_me (LUFS)"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:158
msgid "The average target loudness (measured in LUFS) for the broadcasted stream. Values between -14 and -18 LUFS are common for Internet radio stations."
msgstr "Średni docelowy poziom głośności (mierzony w LUFS) dla nadawanego strumienia. Wartości między -14 a -18 LUFS są powszechne dla internetowych stacji radiowych."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:172
#: frontend/components/Stations/StereoToolConfig.vue:18
msgid "Stereo Tool is an industry standard for software audio processing. For more information on how to configure it, please refer to the"
msgstr "Stereo Tool jest branżowym standardem oprogramowania do przetwarzania dźwięku. Więcej informacji na temat konfiguracji tego narzędzia znajduje się na stronie"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:178
#: frontend/components/Stations/StereoToolConfig.vue:24
msgid "Stereo Tool documentation."
msgstr "Dokumentacja Stereo Tool."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:189
msgid "Stereo Tool License Key"
msgstr "Klucz licencyjny Stereo Tool"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:190
msgid "Provide a valid license key from Thimeo. Functionality is limited without a license key."
msgstr "Podaj ważny klucz licencyjny z Thimeo. Bez klucza licencyjnego funkcjonalność jest ograniczona."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:198
#: frontend/components/Stations/menu.ts:310
#: frontend/components/Stations/StereoToolConfig.vue:12
msgid "Upload Stereo Tool Configuration"
msgstr "Prześlij konfigurację Stereo Tool"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:203
msgid "Upload a Stereo Tool configuration file from the \"Broadcasting\" submenu in the station profile."
msgstr "Prześlij plik konfiguracyjny Stereo Tool z podmenu \"Nadawanie\" w profilu stacji."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:213
#: frontend/components/Admin/Stations/Form/FrontendForm.vue:59
msgid "Advanced Configuration"
msgstr "Konfiguracja zaawansowana"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:215
#: frontend/components/Admin/Stations/Form/FrontendForm.vue:61
#: frontend/components/Admin/Stations/Form/FrontendForm.vue:142
#: frontend/components/Form/FormLabel.vue:16
#: frontend/components/Stations/Media/Form/AdvancedSettings.vue:2
#: frontend/components/Stations/Mounts/Form/Advanced.vue:3
#: frontend/components/Stations/Playlists/Form/Advanced.vue:3
#: frontend/components/Stations/Playlists/Form/BasicInfo.vue:293
#: frontend/components/Stations/Profile/WidgetModal.vue:230
msgid "Advanced"
msgstr "Zaawansowane"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:224
msgid "Share Encoders Between Streams"
msgstr ""

#: frontend/components/Admin/Stations/Form/BackendForm.vue:225
msgid "If you have multiple streams that broadcast in the same format and bitrate, enabling this may significantly improve CPU consumption. Disable this setting if you encounter issues with shared encoding."
msgstr ""

#: frontend/components/Admin/Stations/Form/BackendForm.vue:232
msgid "Manual AutoDJ Mode"
msgstr "Ręczny tryb AutoDJ"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:236
msgid "This mode disables AzuraCast's AutoDJ management, using Liquidsoap itself to manage song playback. \"next song\" and some other features will not be available."
msgstr "Ten tryb wyłącza zarządzanie AutoDJ-em przez AzuraCast, używając samego Liquidsoap do zarządzania odtwarzaniem utworów. \"Następna piosenka\" i niektóre inne funkcje nie będą dostępne."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:245
msgid "Always Write Playlists to Liquidsoap"
msgstr "Zawsze zapisuj playlisty do Liquidsoap"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:246
msgid "By default, all playlists are written to Liquidsoap as a backup in case the normal AutoDJ fails. This can affect CPU load, especially on startup. Disable to only write essential playlists to Liquidsoap."
msgstr "Domyślnie wszystkie playlisty są zapisywane do Liquidsoap jako kopia zapasowa w przypadku awarii normalnego AutoDJ. Może to mieć wpływ na obciążenie procesora, zwłaszcza podczas uruchamiania. Wyłącz, aby zapisać tylko podstawowe playlisty do Liquidsoap."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:255
msgid "Customize Internal Request Processing Port"
msgstr "Dostosuj port wewnętrznego przetwarzania żądania"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:256
msgid "This port is not used by any external process. Only modify this port if the assigned port is in use. Leave blank to automatically assign a port."
msgstr "Ten port nie jest wykorzystywany przez żaden proces zewnętrzny. Zmień port tylko wtedy, gdy ten przypisany jest już używany. Pozostaw puste, aby przypisać port automatycznie."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:265
msgid "AutoDJ Queue Length"
msgstr "Długość kolejki AutoDJ"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:266
msgid "This determines how many songs in advance the AutoDJ will automatically fill the queue."
msgstr "Ta wartość określa, ile piosenek z góry będzie automatycznie wypełniać kolejkę."

#: frontend/components/Admin/Stations/Form/BackendForm.vue:276
msgid "Character Set Encoding"
msgstr "Kodowanie znaków"

#: frontend/components/Admin/Stations/Form/BackendForm.vue:277
msgid "For most cases, use the default UTF-8 encoding. The older ISO-8859-1 encoding can be used if accepting connections from Shoutcast 1 DJs or using other legacy software."
