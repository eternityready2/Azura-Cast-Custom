#: frontend/components/Admin/Stations/Form/AdminForm.vue:31
msgid "The maximum bitrate in which the station allowed to broadcast at, in Kbps. 0 for unlimited."
msgstr "Maximální bitrate, ve kterém může stanice vysílat, v Kbps. 0 znamená neomezený."

#: frontend/components/Admin/Stations/Form/AdminForm.vue:39
msgid "Maximum Mounts"
msgstr "Maximální počet úchytů"

#: frontend/components/Admin/Stations/Form/AdminForm.vue:40
